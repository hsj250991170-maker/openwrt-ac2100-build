#
# ac2100.config —— ImmortalWrt 24.10 / 小米 AC2100 + 红米 AC2100
# 轻量化配置，包含 passwall2 + OpenClash (mihomo 内核)
# 用 make defconfig 自动补全依赖
#

# ============================================================
# Target：MediaTek Ralink MIPS / MT7621 / 小米AC2100 + 红米AC2100
# ============================================================
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
# 多设备编译：同时产出两个型号的固件
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_xiaomi_mi-router-ac2100=y
CONFIG_TARGET_DEVICE_xiaomi_redmi-router-ac2100=y
# 每设备独立 rootfs（避免依赖污染）
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_PER_DEVICE_RECOVERY=y
# SquashFS（支持 Breed 恢复 + overlay 恢复出厂）
CONFIG_TARGET_SQUASHFS=y
# 128MB NAND 不开启压缩，避免运行时 CPU 压力
# CONFIG_TARGET_ROOTFS_TARGZ is not set

# ============================================================
# 基础系统
# ============================================================
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_kmod-nf-tproxy=y
# TUN 设备（passwall/openclash 必需）
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-nf-contrack=y
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y
# 网络诊断工具
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iptables-mod-conntrack-extra=y
CONFIG_PACKAGE_iptables-mod-ipopt=y
CONFIG_PACKAGE_iptables-mod-u32=y
CONFIG_PACKAGE_iptables-mod-filter=y
# IPv6 支持
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# ============================================================
# LuCI Web 界面
# ============================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-mod-admin-full=y
# 中文 + 防火墙界面汉化
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
# Argon 主题（轻量好看）
CONFIG_PACKAGE_luci-theme-argon=y
# 软件包管理界面
CONFIG_PACKAGE_luci-app-opkg=y
# Web 终端（方便调试）
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_ttyd=y

# ============================================================
# 代理：passwall2 + 全套依赖（满足 Ninja 订阅解析需要的协议）
# ============================================================
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y
# passwall2 核心依赖（这些会被自动选中，但显式写明更稳）
CONFIG_PACKAGE_passwall2=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_v2ray-geodata=y
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y
# 兜底代理核心（passwall2 可调用）
# 注意：去掉 naiveproxy（依赖 gn，Ubuntu 22.04 GCC12 编译失败）
# 注意：去掉 shadowsocks-rust（会触发 rustc 源码编译，耗时 1.5 小时；用 libev 版替代）
CONFIG_PACKAGE_trojan-plus=y
CONFIG_PACKAGE_shadowsocks-libev-sslocal=y
CONFIG_PACKAGE_shadowsocks-libev-ssserver=y
CONFIG_PACKAGE_shadowsocks-libev-ssredir=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_dns2tcp=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_tcping=y

# ============================================================
# 代理：OpenClash + mihomo 内核（用于 Ninja 订阅）
#   注：mihomo 内核编译期不下，首次启动时通过 OpenClash 自动下载 mipsel 版
# ============================================================
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y
# OpenClash 依赖
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_coreutils-base64=y
CONFIG_PACKAGE_coreutils-stat=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-bin=y
CONFIG_PACKAGE_kmod-netem=y

# ============================================================
# DNS 增强（passwall2 + OpenClash 都用得上）
# ============================================================
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_smartdns=y

# ============================================================
# 实用工具（精挑细选，不臃肿）
# ============================================================
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-ttyd=y
# 系统监控
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-network=y
# 文件传输（用于上传 ipk）
CONFIG_PACKAGE_luci-app-filetransfer=y
# 自动重启
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y
# 时区同步
CONFIG_PACKAGE_chrony=y

# ============================================================
# 明确不装的（控制体积，避免 make defconfig 自动塞进来）
# ============================================================
# CONFIG_PACKAGE_luci-app-adbyby-plus is not set
# CONFIG_PACKAGE_luci-app-kodexplorer is not set
# CONFIG_PACKAGE_luci-app-aria2 is not set
# CONFIG_PACKAGE_luci-app-transmission is not set
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_luci-app-nlbwmon is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
# CONFIG_PACKAGE_luci-app-ddns is not set
# CONFIG_PACKAGE_luci-app-frpc is not set
# CONFIG_PACKAGE_luci-app-frps is not set
# CONFIG_PACKAGE_luci-app-wol is not set
# CONFIG_PACKAGE_luci-app-uhttpd is not set
# CONFIG_PACKAGE_luci-app-nginx is not set
# CONFIG_PACKAGE_luci-app-qbittorrent is not set
# CONFIG_PACKAGE_luci-app-zerotier is not set

# 关闭 USB 相关（AC2100 没有 USB 口）
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb3 is not set

# 关闭 PPPoE 拨号软件的额外 mod（保留基础 ppp）
# CONFIG_PACKAGE_ppp-mod-pppol2tp is not set
# CONFIG_PACKAGE_ppp-mod-pptp is not set

# 关闭调试符号（减少体积）
# CONFIG_DEBUG is not set
# CONFIG_IPV6 is not set  # IPv6 不关，passwall/openclash 都支持
